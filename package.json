{
  "name": "accomplice",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "style": "prettier  --write \"src/**/*.{ts,tsx}\"",
    "style:ci": "prettier --check \"src/**/*.{ts,tsx}\"",
    "preview": "vite preview",
    "deploy": "run-s build deploy:deno",
    "deploy:deno": "cd dist/ && deployctl deploy --prod --project=kyeotic-accomplice jsr:@kyeotic/server/spa"
  },
  "dependencies": {
    "@solidjs/router": "^0.8.2",
    "byte-base64": "^1.1.0",
    "classnames": "^2.3.2",
    "copy-to-clipboard": "^3.3.3",
    "dexie": "^3.2.4",
    "hotkeys-js": "^3.10.2",
    "lodash": "^4.17.21",
    "markerjs2": "^2.29.1",
    "nanoid": "^4.0.2",
    "pako": "^2.1.0",
    "solid-js": "^1.7.6",
    "solid-transition-group": "^0.2.2"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.195",
    "@types/pako": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "@unocss/preset-wind": "^0.52.7",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.38.0",
    "eslint-plugin-solid": "^0.12.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.24",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.2",
    "unocss": "^0.52.7",
    "vite": "^4.3.9",
    "vite-plugin-solid": "^2.7.0"
  }
}
