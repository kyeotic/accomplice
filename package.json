{
  "name": "untrack",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "run-s build deploy:deno",
    "deploy:deno": "cd dist/ && deployctl deploy --prod --project=kyeotic-unlock https://deno.land/std@0.171.0/http/file_server.ts"
  },
  "dependencies": {
    "@solidjs/router": "^0.8.2",
    "dexie": "^3.2.4",
    "lodash": "^4.17.21",
    "markerjs2": "^2.29.1",
    "nanoid": "^4.0.2",
    "npm-run-all": "^4.1.5",
    "raviger": "^4.1.2",
    "solid-js": "^1.7.6"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.195",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "eslint": "^8.38.0",
    "eslint-plugin-solid": "^0.12.1",
    "typescript": "^5.0.2",
    "unocss": "^0.52.7",
    "vite": "^4.3.9",
    "vite-plugin-solid": "^2.7.0"
  }
}
